class Date extends Triad {

    public Date() {
        super(1, 1, 1);
    }

    public Date(int year, int month, int day) {
        super(year, month, day);
        checkDate(year, month, day);
    }

    // Проверка даты
    private void checkDate(int y, int m, int d) {
        if (y <= 0 || m < 1 || m > 12 || d < 1 || d > 31) {
            System.out.println("Ошибка: некорректная дата!");
            System.exit(1);
        }
    }

    // Get
    public int getYear() { return a; }
    public int getMonth() { return b; }
    public int getDay() { return c; }

    // Set
    public void setYear(int y) {
        checkDate(y, b, c);
        a = y;
    }

    public void setMonth(int m) {
        checkDate(a, m, c);
        b = m;
    }

    public void setDay(int d) {
        checkDate(a, b, d);
        c = d;
    }

    // Сравнение дат
    public boolean equals(Date other) {
        return a == other.a && b == other.b && c == other.c;
    }

    public boolean notEquals(Date other) {
        return !equals(other);
    }

    public boolean greaterThan(Date other) {
        if (a != other.a) return a > other.a;
        if (b != other.b) return b > other.b;
        return c > other.c;
    }

    public boolean lessThan(Date other) {
        if (a != other.a) return a < other.a;
        if (b != other.b) return b < other.b;
        return c < other.c;
    }

    public boolean greaterOrEqual(Date other) {
        return greaterThan(other) || equals(other);
    }

    public boolean lessOrEqual(Date other) {
        return lessThan(other) || equals(other);
    }

    // Строка
    public String toString() {
        return "Date: " + a + "-" + b + "-" + c;
    }
}
