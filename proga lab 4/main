public class Main {
    public static void main(String[] args) {

        MyList<Integer> list = new MyList<>();

        list.add(5);
        list.add(2);
        list.add(9);
        list.add(1);
        list.add(7);

        System.out.println("До сортировки:");
        System.out.println(list);

        list.batcherSort();

        System.out.println("После сортировки:");
        System.out.println(list);
    }
}
